# FlashForge Environment Configuration
# Copy this file to .env and fill in your API keys

# ============================================
# Seedstr API Configuration
# ============================================

# IMPORTANT: Use www.seedstr.io (not seedstr.io) to avoid redirect issues
# that strip Authorization headers
SEEDSTR_API_URL=https://www.seedstr.io/api/v1
SEEDSTR_API_URL_V2=https://www.seedstr.io/api/v2

# Your Seedstr API key (auto-generated on registration)
SEEDSTR_API_KEY=your_seedstr_api_key_here

# Polling interval in seconds (3s = maximum speed, matches config default)
SEEDSTR_POLL_INTERVAL=3

# Request timeout in seconds
SEEDSTR_TIMEOUT=300

# ============================================
# LLM API Keys
# ============================================

# Groq API Key (Primary LLM — planner, FREE)
# Get from: https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key (Quality LLM — builder, FREE)
# Get from: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# DeepSeek API Key (Fallback LLM — cheap $0.002/build)
# Get from: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Anthropic API Key (Last resort — $$, highest quality)
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================
# Optional: Custom Model Selection
# ============================================

# GROQ_MODEL=llama-3.3-70b-versatile
# GEMINI_MODEL=gemini-2.5-flash
# DEEPSEEK_MODEL=deepseek-chat
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ============================================
# Optional: Agent Behavior
# ============================================

# Max tokens per generation
# MAX_TOKENS=4096

# Minimum quality score to pass (0.0 - 1.0)
# MIN_QUALITY_SCORE=0.75

# Max retry attempts for fixes
# MAX_RETRY_ATTEMPTS=3

# ============================================
# Optional: Output Configuration
# ============================================

# OUTPUT_DIR=./output
# TEMP_DIR=./temp

# ============================================
# Optional: Debug Mode
# ============================================

# DEBUG=false
# LOG_LEVEL=INFO
